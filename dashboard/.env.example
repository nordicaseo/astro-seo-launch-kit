# Password you type to log into the dashboard.
DASHBOARD_PASSWORD=change-me

# Long random string used to sign the session cookie.
# Generate one with:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=please-generate-a-long-random-string

# Optional: pre-fill the audit form with your site.
DEFAULT_TARGET=

# Optional: Google PageSpeed Insights API key to enable real Core Web Vitals
# (lab) checks. Without it, performance checks fall back to static heuristics.
# Get one: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
